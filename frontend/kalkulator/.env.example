# Wymagany URL projektu (dowolna nazwa — patrz supabase-config.js)
VITE_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_URL=https://xxxx.supabase.co

# Klucz: w Dashboard → Project Settings → API użyj „anon” / „public” (JWT zaczyna się od eyJ…).
# Możesz też ustawić NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY (jak w projektach Next).
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
