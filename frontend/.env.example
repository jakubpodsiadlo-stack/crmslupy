VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Opcjonalnie — pełny URL API PHP (produkcja). Lokalnie zwykle puste = proxy Vite → :8080
# VITE_API_URL=http://localhost:8080

# Kalkulator (iframe w zakładce „Rzeczoznawca” w podglądzie umowy). Dev: `cd frontend/kalkulator && npm run dev` (port 5174) + proxy `/embed-kalkulator` w CRM.
# Produkcja: zbuduj kalkulator i skopiuj `frontend/kalkulator/dist` → `frontend/public/kalkulator`, albo podaj pełny URL:
# VITE_KALKULATOR_URL=http://localhost:5174

# Cloudinary — upload plików z zakładki Back office → Dodaj pliki (unsigned upload preset w panelu Cloudinary)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
# VITE_CLOUDINARY_FOLDER=first_lead_docs
